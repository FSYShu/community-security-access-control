# 社区安防门禁系统 - 环境配置
# 生产环境敏感配置必须通过环境变量设置

# 数据库
DATABASE_URL=sqlite:///data/security_access.db

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key
SECRET_KEY=change-this-to-a-random-secret-key

# RTMP（推拉流到远程服务器）
RTMP_SERVER_HOST=20.214.147.223
RTMP_SERVER_PORT=9090

# 视频流优化配置
VIDEO_FPS=30
VIDEO_MAX_WIDTH=1280
VIDEO_JPEG_QUALITY=85
VIDEO_BUFFER_SIZE=60

# 通用AI服务（可选）
AI_SERVICE_URL=http://ai-service:8001

# AI日报（硅基流动 OpenAI 兼容接口）
AI_REPORT_PROVIDER=siliconflow
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct
AI_REPORT_ENABLED=true
AI_REPORT_ENDPOINT=/chat/completions
AI_REPORT_TIMEOUT=60
DAILY_REPORT_AUTO_ENABLED=true
DAILY_REPORT_GENERATE_TIME=00:10
DAILY_REPORT_CHECK_INTERVAL=60

# 消息推送
PUSH_SERVICE_URL=http://push-service:8002

# 门禁控制器
GATE_CONTROLLER_HOST=
GATE_CONTROLLER_PORT=9000

# 物业基础系统
PROPERTY_SERVICE_URL=

# 加密
ENCRYPTION_KEY=change-this-encryption-key-in-production

# 备份
BACKUP_DIR=/data/backups
FACE_IMAGE_DIR=/data/face_images
