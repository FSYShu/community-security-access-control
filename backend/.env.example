# 环境配置文件 - 开发环境
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/security_access_dev?charset=utf8mb4

# AI 日报配置（硅基流动 OpenAI 兼容接口）
AI_REPORT_PROVIDER=siliconflow
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct
AI_REPORT_ENABLED=true
AI_REPORT_ENDPOINT=/chat/completions
AI_REPORT_TIMEOUT=60
DAILY_REPORT_AUTO_ENABLED=true
DAILY_REPORT_GENERATE_TIME=00:10

# 消息推送服务配置
PUSH_SERVICE_URL=http://localhost:8002

# 上传文件目录
UPLOAD_FOLDER=uploads

# Redis 配置
REDIS_URL=redis://localhost:6379/0
